{
  "name": "whois-api-proxy",
  "version": "2.0.0",
  "type": "module",
  "description": "Production-ready WHOIS API proxy with Upstash Redis caching, sliding window rate limiting, and stale-if-error resilience",
  "main": "api/whois.js",
  "scripts": {
    "dev": "node --watch api/whois.js",
    "start": "node api/whois.js",
    "test": "node test/rate-limit.js",
    "deploy": "vercel --prod",
    "lint": "eslint api/whois.js"
  },
  "dependencies": {
    "@upstash/ratelimit": "^1.0.0",
    "@upstash/redis": "^1.34.3",
    "cors": "^2.8.5",
    "validator": "^13.12.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "vercel": "^37.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "whois",
    "proxy",
    "api",
    "redis",
    "upstash",
    "rate-limit",
    "sliding-window",
    "cache",
    "vercel",
    "serverless"
  ],
