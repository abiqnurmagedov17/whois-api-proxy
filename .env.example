# ─────────────────────────────────────────────────────
# Upstash Redis (REQUIRED)
# Get from: https://console.upstash.com
# ─────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_api_token_here

# ─────────────────────────────────────────────────────
# Performance Tuning
# ─────────────────────────────────────────────────────
# Cache duration for fresh WHOIS data (seconds)
CACHE_TTL=3600

# How long to keep stale cache for fallback (seconds)
STALE_TTL=86400

# Fetch timeout for upstream API (milliseconds)
FETCH_TIMEOUT=10000

# ─────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────
# Max requests per IP per window
RATE_LIMIT_MAX=30

# Rate limit window duration (seconds)
RATE_LIMIT_WINDOW=60

# ─────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────
PORT=3000